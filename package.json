{
  "type": "module",
  "scripts": {
    "sass": "sass --style=compressed --load-path=node_modules src/assets/sass/site.scss _site/css/site.css",
    "build:js": "esbuild src/assets/js-src/site.js src/assets/js-src/search.js --bundle --minify --target=es2018 --outdir=src/assets/js",
    "watch:js": "esbuild src/assets/js-src/site.js src/assets/js-src/search.js --bundle --minify --target=es2018 --outdir=src/assets/js --watch",
    "build:sw": "node scripts/build-service-worker.mjs",
    "new-post": "node scripts/new-post.mjs",
    "build": "npm run sass && npm run build:js && eleventy",
    "start": "npm-run-all --parallel watch:js start:11ty",
    "start:11ty": "npx eleventy --serve",
    "test": "npx playwright test",
    "unit-test": "npx ava --verbose",
    "format": "prettier . --write",
    "validate:pre": "npm-run-all lint:src lint:tests mdlint lint:tags lint:posts unit-test",
    "validate:post": "npm run lintoutput",
    "lint": "npm-run-all lint:src lint:tests lint:tags lint:posts",
    "lint:src": "npx eslint ./src --max-warnings=0",
    "lint:tests": "npx eslint ./tests --max-warnings=0",
    "lint:js": "npm-run-all lint:src lint:tests",
    "lint:tags": "node scripts/lint-tags.mjs",
    "lint:posts": "node scripts/lint-posts.mjs",
    "mdlint": "markdownlint ./src/content/**/*.md",
    "thumbs": "node ./generate-thumbnails.js",
    "lintoutput": "npx eslint ./_site",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^4.0.2",
    "ava": "^8.0.1",
    "bulma": "^1.0.4",
    "elasticlunr": "^0.9.5",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "shiki": "^3.2.2"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "eleventy-plugin-gen-favicons": "^1.1.3",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "install": "^0.13.0",
    "luxon": "^3.4.4",
    "markdownlint-cli": "^0.48.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.99.0",
    "esbuild": "^0.28.0"
  },
  "ava": {
    "files": [
      "./src/_11ty/filters/**/*.test.js",
      "./src/_11ty/plugins/**/*.test.js",
      "./src/service-worker/*.test.js"
    ]
  }
}
