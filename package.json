{
  "type": "module",
  "scripts": {
    "css": "postcss src/assets/css/site.css -o src/_generated/css/site.css",
    "watch:css": "postcss src/assets/css/site.css -o src/_generated/css/site.css --watch",
    "build:js": "esbuild src/assets/js-src/site.js src/assets/js-src/search.js --bundle --minify --target=es2018 --outdir=src/_generated/js",
    "watch:js": "esbuild src/assets/js-src/site.js src/assets/js-src/search.js --bundle --minify --target=es2018 --outdir=src/_generated/js --watch",
    "build:sw": "node scripts/build-service-worker.mjs",
    "build:og": "node scripts/generate-social-images.mjs",
    "new-post": "node scripts/new-post.mjs",
    "build": "npm-run-all --parallel css build:js build:og && eleventy",
    "start": "npm-run-all --parallel watch:js watch:css start:11ty",
    "start:11ty": "npx eleventy --serve",
    "test": "npx playwright test",
    "unit-test": "npx ava --verbose",
    "format": "prettier . --write",
    "validate:pre": "npm-run-all lint:src lint:tests mdlint lint:tags lint:posts lint:images unit-test",
    "validate:post": "npm run lintoutput",
    "lint": "npm-run-all lint:src lint:tests lint:tags lint:posts lint:images",
    "lint:src": "npx eslint ./src --max-warnings=0",
    "lint:tests": "npx eslint ./tests --max-warnings=0",
    "lint:js": "npm-run-all lint:src lint:tests",
    "lint:tags": "node scripts/lint-tags.mjs",
    "lint:posts": "node scripts/lint-posts.mjs",
    "lint:images": "node scripts/lint-asset-images.mjs",
    "mdlint": "markdownlint ./src/content/**/*.md",
    "thumbs": "node ./generate-thumbnails.js",
    "lintoutput": "node scripts/lint-site-output.mjs",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "ava": "^8.0.1",
    "elasticlunr": "^0.9.5",
    "npm": "^12.0.1",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "cssnano": "^8.0.2",
    "eleventy-plugin-gen-favicons": "^1.1.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "install": "^0.13.0",
    "luxon": "^3.4.4",
    "markdownlint-cli": "^0.49.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.22",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-import-ext-glob": "^2.1.1"
  },
  "overrides": {
    "sharp": "$sharp"
  },
  "ava": {
    "files": [
      "./src/_11ty/filters/**/*.test.js",
      "./src/_11ty/linters/**/*.test.js",
      "./src/_11ty/plugins/**/*.test.js",
      "./src/service-worker/*.test.js",
      "./scripts/lib/**/*.test.js"
    ]
  }
}
