---
pagination:
  data: collections
  size: 1
  alias: tag
  addAllPagesToCollections: true
layout: base.njk
permalink: /tags/{{ tag | slugify }}/
---

{% set taglist = collections[ tag ] %}

{% if topicHub %}
<h1 class="page-title">{{ topicHub.title }}</h1>
<section class="topic-hub-intro" aria-label="Topic introduction">{{ topicHub.intro | safe }}</section>

{% if topicHub.featured and topicHub.featured.length %}
<section aria-labelledby="start-here-heading">
<h2 id="start-here-heading" class="section-title">Start here</h2>
<ul class="mb-m">
  {% for item in topicHub.featured %}
    {% set fp = collections.posts | findPostByUrl(item.url) %}
    {% if fp %}
      <li>
        <a href="{{ fp.url }}">{{ fp.data.title }}</a>
        {% if item.blurb %}: {{ item.blurb }}{% endif %}
      </li>
    {% endif %}
  {% endfor %}
</ul>
</section>
{% endif %}

{% if topicHub.relatedTags and topicHub.relatedTags.length %}
<p class="mb-m">
  Related topics:
  {% for rt in topicHub.relatedTags %}
    {% if collections[rt] and collections[rt].length %}
      <a href="/tags/{{ rt | slugify }}/">#{{ rt }}</a>{% if not loop.last %} · {% endif %}
    {% endif %}
  {% endfor %}
</p>

<hr class="divider" />

{% endif %}

<section aria-labelledby="all-posts-heading">
<h2 id="all-posts-heading" class="section-title">All posts</h2>
{% set postcardlist = taglist | excludePostsByUrls(topicHub.featured) | reverse %}
{% include "partials/post-card-list.njk" %}
</section>

{% else %}
<h1 class="page-title">Posts tagged with #{{ tag }}</h1>
{% set postcardlist = taglist | reverse %}
{% include "partials/post-card-list.njk" %}
{% endif %}

<p class="text-end mt-m">See <a href="/tags/">all tags</a></p>
