{% extends 'layouts/base.njk' %}
{% block precontent %}

{% if thumbnail %}
<section class="mb-m" aria-label="Featured image">
  <figure class="card__media" style="border-radius: var(--border-radius); overflow: hidden;">
    <img src="{{ thumbnail }}" alt="{{ title }}">
  </figure>
</section>
{% endif %}

{% endblock %}

{% block content %}
<article>
  <h1 class="page-title">{{ title }} </h1>
  <div class="site-prose">
  {{ content | safe }}
  </div>
</article>
{% endblock %}

{% block jsonld %}
	{% include "partials/structured-data/about.njk" %}
{% endblock %}
