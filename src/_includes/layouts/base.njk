<!DOCTYPE html>
<html lang="en">
  <head>
    {# 1. Charset/Viewport #}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    {# 2. Title #}
{%- if title -%}
{%- set pageTitle %}{{ title }} | {{ site.title }}{% endset -%}
{%- else -%}
{%- set pageTitle %}{{ site.title }}{% endset -%}
{%- endif -%}
    <title>{{ pageTitle }}</title>
    {# 3. Synchronous JS #}
    {# 4. CSS #}
    {% include "partials/head/stylesheets.njk" %}
    {# 5. Preloads #}
    {# 6. Defer #}
    {# 7. Meta tags, Icons, Open Graph #}
    {%- favicons site.favicon -%}
    {% include "partials/head/meta.njk" %}
    {% block jsonld %}
		  {% include "partials/structured-data/site.njk" %}
    {% endblock %}
    {% if p5embed %}
		  {% include "partials/p5-embed.njk" %}
	  {% endif %}
  </head>
  <body>
	<div id="ios" style="display:none;"><figure class="image">{% include "icons/sad-mac.svg" %}</figure></div>

    {% block header %}
    {% include "partials/siteheader.njk" %}
    {% endblock %}

    <main class="main container mb-6" id="main" >
      {% block precontent %}{% endblock %}

      <section class="section pt-0">
	      <div class="content is-medium">
        {% block content %}
          {{ content | safe }}
        {% endblock %}
        </div>
      </section>

      {% block postcontent %}{% endblock %}
    </main>

    {% block footer %}
    {% include "partials/sitefooter.njk" %}
    {% poison %}
    {% endblock %}

    {% block scripts %}
      {% include "partials/basescripts.njk" %}
      {% if mermaid %}
    	{% include "partials/mermaid-diagrams.njk" %}
      {% endif %}

<script>
  function isIOS() {
  const ua = navigator.userAgent;
  const platform = navigator.platform;

  const iOSPlatforms = [
    "iPad",
    "iPhone",
    "iPod",
    "iPad Simulator",
    "iPhone Simulator"
  ];

  const isIOSPlatform = iOSPlatforms.includes(platform);

  const isIPadOS = ua.includes("Mac") && "ontouchend" in document;

  return isIOSPlatform || isIPadOS;
}

  if (isiOS()) {
    document.getElementById('main').style.display = 'none';
    document.getElementById('header').style.display = 'none';
    document.getElementById('footer').style.display = 'none';
    document.getElementById('ios').style.display = 'block';

  }
</script>
    {% endblock %}
  </body>  
</html>
