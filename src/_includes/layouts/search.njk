{% extends 'layouts/base.njk' %}

{% block content %}

<h1 class="text-4xl font-bold">{{ title }}</h1>

<search>
<form class="my-6" role="search" aria-label="Blog post search" autocomplete="off">
	<fieldset class="d-fieldset">
		<label for="search-box" class="mb-2 block text-sm font-semibold">keywords</label>
		<input type="search" id="search-box" class="d-input w-full search-box" name="query" placeholder="search for posts" spellcheck="false" >
	</fieldset>
</form>
</search>

<section id="search-results" class="flex flex-col gap-4 my-6" aria-live="polite" aria-label="Search results">
{# Empty container for results #}
</section>

<hr />

<section aria-labelledby="recent-posts-heading">
  <h2 id="recent-posts-heading" class="text-xl font-bold">Recent Posts</h2>
  {% set postcardlist = collections.posts | limit(6) %}
  {% include "partials/post-card-list.njk" %}
</section>

{% endblock %}

{% block scripts %}
{% include "partials/searchscripts.njk" %}
{% endblock %}
