{% extends 'layouts/base.njk' %}

{% block content %}

<h1 class="page-title">{{ title }}</h1>

<search>
<form class="mt-m mb-m" role="search" aria-label="Blog post search" autocomplete="off">
	<fieldset class="field">
		<label for="search-box" class="field__label">keywords</label>
		<input type="search" id="search-box" class="field__control search-box" name="query" placeholder="search for posts" spellcheck="false" >
	</fieldset>
</form>
</search>

<section id="search-results" class="search-results" aria-live="polite" aria-label="Search results">
{# Empty container for results #}
</section>

<hr class="divider" />

<section aria-labelledby="recent-posts-heading">
  <h2 id="recent-posts-heading" class="section-title">Recent Posts</h2>
  {% set postcardlist = collections.posts | limit(6) %}
  {% include "partials/post-card-list.njk" %}
</section>

{% endblock %}

{% block scripts %}
{% include "partials/searchscripts.njk" %}
{% endblock %}
