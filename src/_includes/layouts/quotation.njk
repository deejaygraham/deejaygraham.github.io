{% extends 'layouts/post.njk' %}
{% block content %}

{% if comment %}
<section class="py-4">
{{ comment }}
</section>
{% endif %}

{# default to small font size #}
{% set fontSize = 'text-xl' %}
{% set words = content | wordCount %}
{% if words < 100 %}
{% set fontSize = "text-5xl" %}
{% elif words < 500 %}
{% set fontSize = "text-3xl" %}
{% endif %} 

<figure class="quote">
{% include "icons/quotation-mark.svg" %}
        <blockquote class="{{ fontSize }}">
        {{ content | safe }}
        </blockquote>
        <figcaption class="float-right">
        {% if attribution %}&mdash; {{ attribution }}{% endif %}{% if publication %}, {{ publication }}{% endif %}
        </figcaption>
</figure>

{% endblock %}
