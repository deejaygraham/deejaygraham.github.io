{% extends 'layouts/post.njk' %}

{% block articlebody %}
{% if comment %}
<section class="site-prose" aria-label="Commentary">
{{ comment }}
</section>
{% endif %}

{# default to small font size #}
{% set quoteSize = 'quote--s' %}
{% set words = content | wordCount %}
{% if words < 100 %}
{% set quoteSize = "quote--xl" %}
{% elif words < 500 %}
{% set quoteSize = "quote--l" %}
{% endif %}

<figure class="quote mt-m mb-m">
{% include "icons/quotation-mark.svg" %}
        <blockquote class="quote__text {{ quoteSize }}">
        {{ content | safe }}
        </blockquote>
        <figcaption class="quote__caption">
        {% if attribution %}&mdash; {{ attribution }}{% endif %}{% if publication %}, {{ publication }}{% endif %}
        </figcaption>
</figure>
{% endblock %}
