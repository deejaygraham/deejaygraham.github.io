// ---------- Install: precache with TTL ----------
self.addEventListener('install', (event) => {
  if (DEBUG) console.log('[sw] install');
  event.waitUntil((async () => {
    try {
      await precacheWithTTL(coreAssets, PRECACHE);
    } catch (e) {
      if (DEBUG) console.warn('[sw] precacheWithTTL failed:', e);
      // fallback: try addAll (no TTL, but better than nothing)
      const cache = await caches.open(PRECACHE);
      try {
        await cache.addAll(coreAssets);
      } catch (e2) {
        if (DEBUG) console.warn('[sw] addAll fallback failed:', e2);
        // attempt one-by-one
        for (const asset of coreAssets) {
          try { await cache.add(asset); }
          catch (err) { if (DEBUG) console.warn('[sw] cache.add failed:', asset, err); }
        }
      }
    }
    // Note: navigationPreload enabled in 'activate'
    // Consider immediate activation if you prefer:
    // self.skipWaiting();
  })());
});

// ---------- Activate: cleanup & claim ----------
self.addEventListener('activate', (event) => {
  if (DEBUG) console.log('[sw] activate');
  event.waitUntil((async () => {
    const allow = new Set([PRECACHE, RUNTIME, IMAGE_CACHE]);
    const keys = await caches.keys();
    await Promise.all(
      keys.filter((k) => !allow.has(k)).map((k) => caches.delete(k))
    );

    // Enable navigation preload after activation
    if ('navigationPreload' in self.registration) {
      try { await self.registration.navigationPreload.enable(); }
      catch (e) { if (DEBUG) console.warn('[sw] navigationPreload enable failed:', e); }
    }
    await self.clients.claim();
  })());
});

// ---------- Fetch routing ----------
self.addEventListener('fetch', (event) => {
  const { request } = event;
  if (request.method !== 'GET') return;

  const url = new URL(request.url);

  // If you ever add media with range requests, you can bypass here:
  // if (request.headers.has('range')) return;

  // 1) HTML / navigations: Network-first with 404/offline fallbacks
  if (request.mode === 'navigate' || request.destination === 'document') {
    event.respondWith(handleNavigation(event));
    return;
  }

  // 2) Static assets (same-origin CSS/JS): SWR with TTL
  const isCssJs =
    url.origin === self.location.origin &&
    (request.destination === 'style' ||
      request.destination === 'script' ||
      /\.(css|js)$/.test(url.pathname));

  if (isCssJs) {
    event.respondWith(staleWhileRevalidateWithTTL(request, RUNTIME, event));
    return;
  }

  // 3) Images (same-origin): Cache-first with cap + TTL
  const isImage =
    url.origin === self.location.origin &&
    (request.destination === 'image' || /\.(png|jpe?g|gif|webp|svg)$/.test(url.pathname));

  if (isImage) {
    event.respondWith(cacheFirstWithLimitAndTTL(request, IMAGE_CACHE, 150));
    return;
  }

  // 4) Default: try cache (with TTL), then network
  event.respondWith(cacheThenNetworkWithTTL(request, RUNTIME));
});

// Optional update control
self.addEventListener('message', (event) => {
  if (event.data === 'SKIP_WAITING') self.skipWaiting();
});
