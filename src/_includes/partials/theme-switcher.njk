{# ids are used by injected js switcher #}
<nav class="text-center" aria-label="theme-switcher">
    <fieldset class="button-group field">
        <legend class="sr-only">Colour theme</legend>
        <button type="button" id="light-theme-toggle" data-theme="light" class="button" aria-label="Light mode">Light</button>
        <button type="button" id="dark-theme-toggle" data-theme="dark" class="button" aria-label="Dark mode">Dark</button>
        <button type="button" id="system-theme-toggle" data-theme="system" class="button" aria-label="Device default">Default</button>
    </fieldset>
</nav>
