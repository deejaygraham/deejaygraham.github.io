{# Requires item with url, thumbnail, title, (optional) subtitle #}
<article class="card">
  <figure class="card__media">
    <a href="{{ item.url }}" target="_blank" rel="noreferrer">
      <img src="{{ item.thumbnail }}" alt="{{ item.title }}" />
    </a>
  </figure>
  <section class="card__body">
    <h2 class="post-card-title">{% externalLink item.url, item.title %}</h2>
    {% if item.subtitle %}
    <p class="post-card-meta">{{ item.subtitle }}</p>
    {% endif %}
  </section>
</article>
