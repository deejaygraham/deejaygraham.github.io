{# Requires a global variable to be set called post with url, title, date, tags (array) #}
<div class="column is-4">
  <div class="card large is-shadowless">	
    <a href="{{ url }}">{{ title }}
  	<div class="card-content">
    {% if tags %}
      <p class="mb-0">{%- for tag in tags -%}{{ tag }}{% if not loop.last %} | {% endif %}{%- endfor -%}</p>
    {% endif %}
      <h2 class="title"><a href="{{ url }}">{{ title }}</a></h2>
      {% if subtitle %}
      <p class="subtitle is-pulled-left">{{ subtitle }}</p>
      {% endif %}
      {%- if excerpt -%}
      <div class="content">{{ excerpt }}</div>
      {%- endif -%}
      {%- if date -%}
      <p class="is-pulled-left"><time datetime="{{ date | dateISO }}">{{ date | dateFull }}</time></p>
      {%- endif -%}
    </div>
    </a>
  </div>
</div>  
