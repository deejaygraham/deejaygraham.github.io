{# Requires url, title, date, tags (array); optional subtitle, excerpt #}
<article class="card">
  <a href="{{ url }}" class="card__body">
    {% if tags %}
      <p class="post-card-meta">{%- for tag in tags -%}{{ tag }}{% if not loop.last %} · {% endif %}{%- endfor -%}</p>
    {% endif %}
      <h2 class="post-card-title">{{ title }}</h2>
      {% if subtitle %}
      <p class="text-muted">{{ subtitle }}</p>
      {% endif %}
      {%- if excerpt -%}
      <p class="text-muted">{{ excerpt }}</p>
      {%- endif -%}
      {%- if date -%}
      <p class="post-card-meta"><time datetime="{{ date | dateISO }}">{{ date | dateFull }}</time></p>
      {%- endif -%}
  </a>
</article>
