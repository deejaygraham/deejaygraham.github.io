<!-- partials/siteheader -->
<header class="site-header" id="header">
  <a href="#main" class="skip-link">Skip to main content</a>
  {% poison %}
  <nav class="site-nav" aria-label="main navigation">
    <div class="cluster">
      <details class="site-nav__mobile">
        <summary class="site-nav__menu-toggle" aria-label="menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </summary>
        <div class="site-nav__menu-panel">
          <ul class="site-nav__list" role="menu">
            {% include "partials/navigation-list.njk" %}
          </ul>
        </div>
      </details>
      {% include "partials/navigation-brand.njk" %}
    </div>
    <div class="site-nav__desktop">
      <ul class="site-nav__list">
        {% include "partials/navigation-list.njk" %}
      </ul>
    </div>
  </nav>
</header>
<!-- partials/siteheader -->
