{# Requires a global variable to be set "postcardlist" #}
<ul class="auto-grid">
	{% for post in postcardlist %}
		<li>
			{% set url =  post.url %}
			{% set title =  post.data.title %}
			{% set subtitle =  post.data.subtitle %}
			{# set date =  post.date #}
			{% set tags =  post.data.tags %}
			{% include "partials/post-card.njk" %}
		</li>
	{% endfor %}
</ul>
